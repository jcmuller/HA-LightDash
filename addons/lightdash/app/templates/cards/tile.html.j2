<div class="ha-card tile-card"{% if color %} style="--tile-color: {{ color }}"{% endif %}>
  {% if features_inline and has_features %}
  <div class="{{ tc_class }}"{{ ta_attrs }}>
    <div class="tile-icon">{{ icon }}</div>
    <div class="tile-info tile-info-inline">
      <div class="tile-name">{{ name }}</div>
      {{ inline_features }}
    </div>
  </div>
  {% elif is_cover and not hide_state %}
  <div class="{{ tc_class }}"{{ ta_attrs }}>
    <div class="tile-icon">{{ icon }}</div>
    <div class="tile-info tile-info-inline">
      <div class="tile-name">{{ name }}</div>
      {{ state_html }}{{ cover_html }}
    </div>
  </div>
  {% else %}
  <div class="{{ tc_class }}"{{ ta_attrs }}>
    <div class="tile-icon">{{ icon }}</div>
    <div class="tile-info">
      <div class="tile-name">{{ name }}</div>
      {{ state_html }}
    </div>
  </div>
  {{ features_html }}
  {% endif %}
</div>
