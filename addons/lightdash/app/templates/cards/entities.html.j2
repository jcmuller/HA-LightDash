<div class="ha-card entities-card">
  {% if title %}<div class="entities-header">{{ title }}</div>{% endif %}
  {% for row in rows %}
    {% if row.type == "divider" %}
    <hr class="entities-divider">
    {% elif row.type == "section" %}
    <div class="entities-section-header">{{ row.name }}</div>
    {% else %}
    <div{{ row.attrs }}>
      <div class="entity-icon">{{ row.icon }}</div>
      <div class="entity-info">
        <div class="entity-name">{{ row.name }}</div>
        {{ row.state_span }}
      </div>
      {{ row.controls }}
    </div>
    {% endif %}
  {% endfor %}
</div>
