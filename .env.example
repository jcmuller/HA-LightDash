# HA connection (optional — offline mode works without these)
HA_URL=http://homeassistant.local:8123
HA_TOKEN=your_long_lived_access_token_here

# Fetch dashboard from HA API (set to "lovelace" or your dashboard url_path)
# If unset or HA not available, falls back to CONFIG_PATH
# DASHBOARD_PATH=lovelace

# Local config fallback (used when DASHBOARD_PATH is unset or HA unavailable)
CONFIG_PATH=config/living_room.yaml

# Server
HOST=0.0.0.0
PORT=8000
RELOAD=true
